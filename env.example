# Backend Configuration
NODE_ENV=production
PORT=5000

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=*
DB_PASSWORD=*
DB_NAME=*

# Rust Database Configuration (read-only)
RUST_DB_HOST=localhost
RUST_DB_PORT=3306
RUST_DB_USER=*
RUST_DB_PASSWORD=*
RUST_DB_NAME=*

# Steam API Configuration
# Получите ключ на: https://steamcommunity.com/dev/apikey
STEAM_API_KEY=*
STEAM_RETURN_URL=https://dragonlost.ru/api/auth/steam/return
STEAM_REALM=https://dragonlost.ru

# Session Configuration
# Сгенерируйте случайную строку: openssl rand -base64 32
SESSION_SECRET=*

# Ключ шифрования данных сессий в БД (AES-256-GCM)
# Сгенерируйте ключ: openssl rand -base64 32
# ВНИМАНИЕ: смена ключа инвалидирует все существующие сессии!
SESSION_ENCRYPTION_KEY=*

# CORS Configuration
CORS_ORIGIN=https://dragonlost.ru

# Frontend Configuration (для frontend/.env)
VITE_API_URL=https://dragonlost.ru/api
RUST_SERVERS_API_KEY=*


RCON_HOST=*     # IP вашего Rust-сервера (должен быть доступен с машины, где крутится backend)
RCON_PORT=*            # Порт RCON (по умолчанию 28016)
RCON_PASSWORD=*   # Пароль RCON из server.cfg

# Пятница 17:30 МСК: вайп по победителю голосования (seed/size).
# GAME_SERVER_WIPE_CRON=false — отключить перезапуск целиком.
#
# SurvivalHost (https://my.survivalhost.org): публичного API «номер карты» в вики нет
# (есть API машин: https://survivalhost.wiki/SurvivalHost_API — не про игровой Rust).
# Режим RCON: команды в консоль сервера, затем quit — панель поднимает процесс снова.
# GAME_SERVER_WIPE_VIA_RCON=true
# По умолчанию: server.seed и server.worldsize (Rust). Для других имён конваров:
# RCON_WIPE_SEED_CONVAR=server.seed
# RCON_WIPE_SIZE_CONVAR=server.worldsize
# RCON_WIPE_SEND_QUIT=false — только выставить конвары без остановки (для отладки)
#
# Альтернатива: Pterodactyl Client API или свой вебхук — см. репозиторий / документацию gameServerPanel.ts

# Discord-уведомлений выбора карты:
DISCORD_ADMIN_WEBHOOK_URL=*

# RustMaps API (превью карт по seed/size)
# Получите ключ на: https://rustmaps.com/dashboard
RUSTMAPS_API_KEY=*